---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Prøvetræning og kontakt - Måløv Judoklub" description="Kontakt Måløv Judoklub og book en prøvetræning for børn, unge eller voksne. Find adresse, telefon, email og træningstider her.">
  <Header />

  <main class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Book en prøvetræning</h1>
        <p class="text-xl text-gray-600">Har du spørgsmål eller vil du i gang? Skriv til os, så finder vi det rigtige hold.</p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-semibold mb-6">Det praktiske</h2>

          <div class="mb-8 rounded-2xl bg-primary-dark text-white p-6">
            <h3 class="text-lg font-semibold mb-3">Sådan foregår det</h3>
            <ol class="space-y-3 text-sm text-white/90 list-decimal list-inside">
              <li>Udfyld formularen eller ring til os</li>
              <li>Vi peger dig mod det rigtige hold</li>
              <li>Du møder op i almindeligt træningstøj</li>
              <li>Du prøver 2 uger gratis</li>
            </ol>
          </div>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="text-2xl">📍</span>
              </div>
              <div>
                <h3 class="font-semibold">Adresse</h3>
                <p class="text-gray-600">Måløv Hovedgade 50<br/>2760 Måløv</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="text-2xl">📧</span>
              </div>
              <div>
                <h3 class="font-semibold">Email</h3>
                <a href="mailto:mjkjudo@gmail.com" class="text-gray-600 hover:text-accent">mjkjudo@gmail.com</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="text-2xl">📞</span>
              </div>
              <div>
                <h3 class="font-semibold">Telefon</h3>
                <a href="tel:21418406" class="text-gray-600 hover:text-accent">21 41 84 06</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="text-2xl">🕐</span>
              </div>
              <div>
                <h3 class="font-semibold">Træningstider</h3>
                <p class="text-gray-600">Tirsdag & Torsdag<br/>Børn: 18:00-19:00<br/>Ungdom/Voksne: 19:00-21:00</p>
                <p class="text-accent text-sm">Mød bare op eller skriv til os først.</p>
              </div>
            </div>
          </div>

          <div class="mt-8 p-6 bg-accent/5 border border-accent/20 rounded-xl">
            <h3 class="font-semibold text-accent mb-2">🎁 Prøv 2 uger gratis</h3>
            <p class="text-gray-600 text-sm">
              Du er altid velkommen til at møde op og prøve judo uden at melde dig ind. 
              Tag løst tøj på og vær klar til at svede!
            </p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-white border border-gray-200 rounded-2xl p-8">
          <h2 class="text-2xl font-semibold mb-6">Send os en besked</h2>
          
          <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-4">
            <input type="hidden" name="subject" value="Ny forespørgsel om prøvetræning - Måløv Judoklub" />
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Navn</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent"
                placeholder="Dit navn"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent"
                placeholder="din@email.dk"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Telefon (valgfrit)</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent"
                placeholder="12 34 56 78"
              />
            </div>

            <div>
              <label for="interest" class="block text-sm font-medium text-gray-700 mb-1">Jeg er interesseret i</label>
              <select 
                id="interest" 
                name="interest"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent"
              >
                <option value="">Vælg...</option>
                <option value="born">Børnehold (7-11 år)</option>
                <option value="ungdom-voksen">Ungdoms- og voksenhold (12+ år)</option>
                <option value="usikker">Ved ikke / Vil høre mere</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Besked</label>
              <textarea 
                id="message" 
                name="message" 
                rows="4"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent"
                placeholder="Skriv fx alder, om det er til dit barn eller dig selv, og hvornår I gerne vil starte."></textarea>
            </div>

            <button 
              type="submit"
              class="w-full px-6 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent-dark transition-colors"
            >
              Send forespørgsel om prøvetræning
            </button>
          </form>

          <p class="text-xs text-gray-500 mt-4">
            Vi vender tilbage inden for 24 timer. Du kan også ringe direkte på 21 41 84 06.
          </p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>