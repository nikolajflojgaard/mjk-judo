---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Træningstider - Måløv Judoklub">
  <Header />

  <main class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Træningstider</h1>
        <p class="text-gray-600">Vi træner fast flere gange om ugen. Find det hold der passer dig.</p>
      </div>

      <div class="space-y-6">
        <!-- Børnehold -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center">
              <span class="text-2xl">🧒</span>
            </div>
            <div>
              <h2 class="text-xl font-semibold">Børnehold (7-11 år)</h2>
              <p class="text-sm text-gray-500">Begyndere og let øvede</p>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-gray-50 p-4 rounded-lg">
              <div class="font-medium text-primary">Tirsdag</div>
              <div class="text-lg font-semibold">17:00 - 18:00</div>
            </div>
            <div class="bg-gray-50 p-4 rounded-lg">
              <div class="font-medium text-primary">Torsdag</div>
              <div class="text-lg font-semibold">17:00 - 18:00</div>
            </div>
          </div>
        </div>

        <!-- Ungdom & Voksne -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
              <span class="text-2xl">👦</span>
            </div>
            <div>
              <h2 class="text-xl font-semibold">Ungdom & Voksne (12+ år)</h2>
              <p class="text-sm text-gray-500">Øvede og alle niveauer</p>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-gray-50 p-4 rounded-lg">
              <div class="font-medium text-primary">Tirsdag</div>
              <div class="text-lg font-semibold">19:30 - 21:00</div>
            </div>
            <div class="bg-gray-50 p-4 rounded-lg">
              <div class="font-medium text-primary">Torsdag</div>
              <div class="text-lg font-semibold">19:30 - 21:00</div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-12 bg-primary/5 border border-primary/20 rounded-2xl p-8 text-center">
        <h3 class="text-xl font-semibold mb-2">Kom og prøv det af</h3>
        <p class="text-gray-600 mb-6">
          Du er altid velkommen til at møde op og prøve judo inden du melder dig ind. 
          Tag noget løst tøj på og vær klar til at svede.
        </p>
        <a 
          href="/kontakt" 
          class="inline-flex items-center px-6 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent-dark transition-colors"
        >
          Skriv til os før du kommer
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>